<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>오늘하나</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>오늘하나</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>whatsnext</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!-- MVP: required for Vision OCR screenshot import -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Select a screenshot to extract your schedule from it.</string>
	<!-- MVP: required for Speech transcription (audio file import) -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Transcribe audio files to extract schedule items.</string>
	<!-- MVP: required for future live microphone recording -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Record a voice memo to extract schedule items.</string>
	<!-- MVP: required for EventKit Calendar write access -->
	<key>NSCalendarsWriteOnlyAccessUsageDescription</key>
	<string>Save confirmed events directly to your calendar.</string>
	<!-- MVP: required for Reminders access -->
	<key>NSRemindersUsageDescription</key>
	<string>Save confirmed reminders directly to your Reminders app.</string>
	<key>WHATSNEXT_APP_GROUP_IDENTIFIER</key>
	<string>$(WHATSNEXT_APP_GROUP_IDENTIFIER)</string>
	<key>WHATSNEXT_OPERATOR_NAME</key>
	<string>$(WHATSNEXT_OPERATOR_NAME)</string>
	<key>WHATSNEXT_PRIVACY_POLICY_URL</key>
	<string>$(WHATSNEXT_PRIVACY_POLICY_URL)</string>
	<key>WHATSNEXT_SUPPORT_EMAIL</key>
	<string>$(WHATSNEXT_SUPPORT_EMAIL)</string>
</dict>
</plist>
